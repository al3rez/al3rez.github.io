---
interface Props {
  post: CollectionEntry<"posts">;
}

import type { CollectionEntry } from "astro:content";
import EmailLink from "./email-link.astro";
import Layout from "./layout.astro";

const { post } = Astro.props;
const { Content } = await post.render();
const postDate = post.data.date?.toISOString().slice(0, 10);
const publishedTime = post.data.date?.toISOString();
const pageTitle = `${post.data.title} — al3rez`;
---

<Layout
  title={pageTitle}
  description={post.data.description ?? undefined}
  type="article"
  publishedTime={publishedTime}
>
  <main>
    <article class="post-content">
      <h1>{post.data.title}</h1>
      {
        postDate && (
          <p>
            <time datetime={postDate}>
              <em>{postDate}</em>
            </time>
          </p>
        )
      }
      <Content />
    </article>
  </main>
  <hr />
  <footer class="site-footer" aria-label="Site footer">
    <a href="/">Index</a>
    <a href="https://github.com/al3rez" rel="me">github.com/al3rez</a>
    <a href="https://twitter.com/al3rez" rel="me">twitter.com/al3rez</a>
    <EmailLink />
  </footer>
</Layout>
